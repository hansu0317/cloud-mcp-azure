# ─── 앱 이름 (UI 타이틀, 사이드바 연결명 등) ────────────────────────────────────
VITE_APP_NAME=Quali CRM
VITE_CONN_NAME=Quali Cloud

# ─── 서버 포트 ────────────────────────────────────────────────────────────────
PORT=3000

# ─── 환경 구분 ─────────────────────────────────────────────────────────────────
NODE_ENV=production

# ─── Claude 타임아웃 ───────────────────────────────────────────────────────────
# 채팅 응답 최대 대기 시간(ms). MCP 조회 포함 평균 20~40초. 120초 권장
CHAT_TIMEOUT_MS=120000

# 테이블 스키마 describe 타임아웃(ms)
DESCRIBE_TIMEOUT_MS=60000

# Graceful Shutdown 강제 종료 대기(ms)
SHUTDOWN_TIMEOUT_MS=30000

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
# 분당 IP당 최대 요청 수. 사용자 규모에 맞게 조정 (10명 사내 → 20 정도 적절)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20

# ─── 동시 접속 제한 (M2) ──────────────────────────────────────────────────────
# 동시 실행 가능한 Claude 프로세스 최대 수. 서버 RAM 기준: 2GB→3, 4GB→5, 8GB→10
MAX_CONCURRENT_CLAUDE=5

# ─── 세션 관리 (M5) ───────────────────────────────────────────────────────────
# 메모리에 유지할 최대 세션 수. 초과 시 가장 오래된 세션부터 정리
MAX_SESSIONS=200

# ─── API 키 인증 (M1) ─────────────────────────────────────────────────────────
# 설정하면 모든 /api/* 요청에 X-API-Key 헤더 필수. 비워두면 인증 없이 동작
# 사내망 전용이라도 설정 권장. 예: openssl rand -hex 32
API_KEY=

# ─── Claude API 경로 (claudeapi/, 선택) ──────────────────────────────────────
# POST /api/chat-api 용. 미설정 시 해당 경로만 비활성(기존 CLI 경로는 정상 동작)
# Dataverse Web API를 서비스 주체(client_credentials)로 직접 조회
ANTHROPIC_API_KEY=
DATAVERSE_TENANT_ID=
DATAVERSE_CLIENT_ID=
DATAVERSE_CLIENT_SECRET=
DATAVERSE_URL=https://quali.crm5.dynamics.com
# 아래는 선택 (기본값 있음)
# ANTHROPIC_MODEL=claude-haiku-4-5
# ANTHROPIC_MAX_TOKENS=4096

# ─── 로그 ─────────────────────────────────────────────────────────────────────
# 로그 파일 보관 일수 (rotating-file-stream 자동 회전)
LOG_MAX_FILES=30
