# Nginx 리버스 프록시 설정 예제
# 복사 후 수정: cp nginx.conf.example /etc/nginx/sites-available/crm-chat
# 활성화: ln -s /etc/nginx/sites-available/crm-chat /etc/nginx/sites-enabled/
# 재시작: nginx -t && systemctl reload nginx

server {
    listen 80;
    server_name your-domain.internal;  # 실제 도메인 또는 IP로 변경

    # HTTP → HTTPS 리다이렉트 (TLS 설정 후 활성화)
    # return 301 https://$host$request_uri;

    # SSE 스트리밍 필수 설정
    proxy_buffering          off;
    proxy_cache              off;
    proxy_read_timeout       330s;  # CHAT_TIMEOUT_MS(120s) + 여유
    proxy_connect_timeout    10s;
    proxy_send_timeout       30s;

    location / {
        proxy_pass         http://localhost:3000;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        keep-alive;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }
}

